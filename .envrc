# shellcheck disable=SC2148
export DIRENV_WARN_TIMEOUT=0
export NIXPKGS_ALLOW_UNFREE=1
use flake . --impure

export_sops_secret() {
  local var_name="$1" file="$2" key="$3" value
  if value=$(sops -d --extract "$key" "$file" 2>/dev/null); then
    export "$var_name=$value"
  else
    echo "direnv: skipping $var_name (could not decrypt $file)" >&2
  fi
}

export_sops_secret CLOUDFLARE_API_TOKEN secrets/cloudflare.yaml '["api_token"]'
export_sops_secret HCLOUD_TOKEN secrets/hetzner.yaml '["api_token"]'
