# shellcheck disable=SC2148
export DIRENV_WARN_TIMEOUT=0
export NIXPKGS_ALLOW_UNFREE=1
use flake . --impure

CLOUDFLARE_API_TOKEN="$(sops -d --extract '["api_token"]' secrets/cloudflare.yaml)"
export CLOUDFLARE_API_TOKEN

HCLOUD_TOKEN="$(sops -d --extract '["api_token"]' secrets/hetzner.yaml)"
export HCLOUD_TOKEN
